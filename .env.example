PORT=3001
CORS_ORIGIN=http://localhost:5173
# Path to the SQLite database file. In production on Fly, point this at the
# volume mount (e.g. /app/data/aim.db) so data survives redeploys.
DB_PATH=aim.db
# Shared secret for /admin/* endpoints. If unset, admin routes return 503.
# Set in production via: fly secrets set ADMIN_TOKEN=$(openssl rand -hex 32)
ADMIN_TOKEN=
